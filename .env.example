# Server port
PORT=8080

# Public WebSocket URL for Twilio to connect to (e.g., wss://your-ngrok-id.ngrok.io/ws)
WS_URL=wss://your-domain.ngrok.io/ws

# LCA AudioHook WebSocket endpoint (from CloudFormation Outputs → WebSocketEndpoint)
LCA_ENDPOINT=wss://xxxxxxxxxx.cloudfront.net

# Organization ID for AudioHook protocol (UUID format)
LCA_ORG_ID=00000000-0000-0000-0000-000000000000

# Optional: API key for LCA authentication
LCA_API_KEY=

# AWS region (for future SigV4 auth in Phase 3)
AWS_REGION=us-east-1

# Amazon Transcribe settings
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_SAMPLE_RATE=16000

# IAM needs: transcribe:StartCallAnalyticsStreamTranscription

# Twilio Client SDK (for browser-based agent softphone)
# Get these from Twilio Console:
# Account SID: https://console.twilio.com (Dashboard → Account SID, starts with AC...)
# TwiML App SID: https://console.twilio.com/us1/develop/voice/manage/twiml-apps (starts with AP...)
# API Key: https://console.twilio.com/us1/account/keys-credentials/api-keys (SID starts with SK...)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
