{
  "name": "lca-relay",
  "version": "1.0.0",
  "description": "Twilio Media Streams to AWS Live Call Analytics relay server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock-lca": "tsx src/mockLcaServer.ts",
    "agent": "tsx src/agents/worker.ts start",
    "setup-sip": "tsx src/setupSip.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-comprehend": "^3.1022.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1021.0",
    "@livekit/agents": "^1.2.2",
    "@livekit/agents-plugin-deepgram": "^1.2.2",
    "@livekit/agents-plugin-livekit": "^1.2.2",
    "@livekit/agents-plugin-openai": "^1.2.2",
    "@livekit/agents-plugin-silero": "^1.2.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "livekit-server-sdk": "^2.15.0",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
